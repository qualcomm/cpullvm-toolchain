+#---IFuncs.test--------------------- Exe------------------#
+#BEGIN_COMMENT
+# This test verifies the IFUNC support when building AArch64 static executables.
+#END_COMMENT
+#START_TEST
+RUN: %clang %clangopts --target=aarch64-linux-gnu -o %t1.1.o %p/Inputs/1.c -c
